<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:scrollbars="none"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/player"
            android:text="@string/play_exo"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/decode"
            android:text="@string/play_decode"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/speed"
            android:text="@string/play_speed"
            android:fontFeatureSettings="tnum"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/scale"
            android:text="@string/play_scale"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/reset"
            android:text="@string/play_reset"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/loop"
            android:text="@string/play_loop"
            style="@style/Control"/>
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text"
            android:tag="3"
            android:text="@string/play_track_text"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/audio"
            android:tag="1"
            android:text="@string/play_track_audio"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/video"
            android:tag="2"
            android:text="@string/play_track_video"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/opening"
            android:text="@string/play_op"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/ending"
            android:text="@string/play_ed"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/danmaku"
            android:visibility="gone"
            android:text="@string/danmaku"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/title"
            android:visibility="gone"
            android:text="@string/play_title"
            style="@style/Control"/>
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/episodes"
            android:text="@string/detail_episode"
            style="@style/Control"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</HorizontalScrollView>
