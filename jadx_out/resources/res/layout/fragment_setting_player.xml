<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIconTint="@android:color/white"
        app:title="@string/setting_player"
        app:titleTextAppearance="@style/ToolbarTextAppearance"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:animateLayoutChanges="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/render"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_render"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/renderText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/playerEngine"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_engine"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/playerEngineText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/rtspTransport"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_rtsp_transport"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/rtspTransportText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/zteNatAuto"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_zte_nat_auto"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/zteNatAutoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/hidePlayUrl"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_hide_play_url"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/hidePlayUrlText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/scale"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_scale"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/scaleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/caption"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_caption"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:ellipsize="middle"
                    android:gravity="end"
                    android:id="@+id/captionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/buffer"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_buffer"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/bufferText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/times"
                    android:layout_marginStart="4dp"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/speed"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_speed"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/speedText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/times"
                    android:layout_marginStart="4dp"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/tunnel"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_tunnel"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/tunnelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/audioDecode"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_audio_decode"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/audioDecodeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/videoDecode"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_video_decode"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/videoDecodeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/aac"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_aac_track"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/aacText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/danmakuLoad"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_danmaku_load"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/danmakuLoadText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/adblock"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_adblock"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/adblockText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/background"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_background"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:gravity="end"
                    android:id="@+id/backgroundText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/ua"
                android:background="@drawable/shape_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_ua"
                    android:layout_marginEnd="16dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:ellipsize="middle"
                    android:gravity="end"
                    android:id="@+id/uaText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
</androidx.appcompat.widget.LinearLayoutCompat>
